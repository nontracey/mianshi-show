# ===== 知识库数据源 =====
# 默认走公开 manifest(任何人 clone 即可跑);离线时改用本地 clone 路径
KB_CONTENT_URL=https://raw.githubusercontent.com/nontracey/mianshi-zhilian-content/main/manifest.json
KB_CONTENT_PATH=

# 本地样例数据(供离线快速跑通流程,优先级低于 KB_CONTENT_PATH)
KB_SAMPLE_PATH=../data/knowledge_base.sample.json

# ===== LLM / Embedding(OpenAI 兼容,可切通义/DeepSeek/OpenAI/本地) =====
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ===== 向量库 =====
# VECTOR_STORE: memory(默认,零依赖,dev/demo) | chroma(持久化) | pgvector(prod)
VECTOR_STORE=memory
CHROMA_PATH=./chroma_data
PGVECTOR_URL=

# ===== 缓存 =====
# 空 -> 用 fakeredis(dev)
REDIS_URL=

# ===== 服务 =====
APP_HOST=0.0.0.0
APP_PORT=8000
RATE_LIMIT_PER_MINUTE=20

# ===== 可选:LangSmith 观测 =====
LANGCHAIN_TRACING_V2=
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=
